{
    "tech_stack": [
        "javascript",
        "express",
        "mongoose",
        "node-fetch"
    ],
    "features": [
        {
            "name": "Generate Image",
            "description": "Generates AI image using configured provider (MiniMax, Stability, OpenAI) or falls back to Pollinations.",
            "files": [
                "server.full.js",
                "models.js"
            ],
            "api_doc": {
                "openapi": "3.0.0",
                "paths": {
                    "/api/generation/generate": {
                        "post": {
                            "summary": "Generate Image",
                            "requestBody": {
                                "content": {
                                    "application/json": {
                                        "schema": {
                                            "type": "object",
                                            "properties": {
                                                "prompt": {
                                                    "type": "string"
                                                },
                                                "userPrompt": {
                                                    "type": "string"
                                                },
                                                "templateId": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    }
                                }
                            },
                            "responses": {
                                "200": {
                                    "description": "Success"
                                }
                            }
                        }
                    }
                }
            }
        }
    ]
}